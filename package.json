{
  "name": "cypress-multi-env",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:headed": "cypress run --headed",
    "dev": "cypress run --env configFile=dev --headed",
    "prod": "cypress run --env configFile=prod --headed",
    "stage": "cypress run --env configFile=stage --headed",
    "dev:headless": "cypress run --env configFile=dev",
    "cy:grep:sanity": "cypress run --env configFile=dev,grepTags=@sanity --headed",
    "cy:grep:sanity:prod": "cypress run --env configFile=prod,grepTags=@sanity --headed",
    "cy:grep:regression": "cypress run --env configFile=dev,grepTags=@regression --headed",
    "cy:grep:regression:prod": "cypress run --env configFile=prod,grepTags=@regression --headed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "cypress": "^15.13.0",
    "@cypress/grep": "^6.0.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
